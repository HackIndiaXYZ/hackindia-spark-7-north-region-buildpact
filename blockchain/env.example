PRIVATE_KEY=0xYOUR_PRIVATE_KEY
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

CLIENT_ADDRESS=0xYourClientWalletAddress
ORACLE_ADDRESS=0xYourOracleWalletAddress
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add .env to your .gitignore.

# ── Deployer ───────────────────────────────────────────────────────────────────
# Private key of the wallet that will sign deployment transactions.
# Must hold Amoy POL to pay gas. With 0x prefix is safest.
PRIVATE_KEY=0xyour_private_key_here

# ── RPC Endpoint ───────────────────────────────────────────────────────────────
# A dedicated Alchemy / Infura / QuickNode endpoint is strongly recommended.
# If left blank, the script falls back to the public Amoy RPC (rate-limited).
#   Alchemy  → https://www.alchemy.com/
#   Infura   → https://www.infura.io/
#   QuickNode→ https://www.quicknode.com/
AMOY_RPC_URL=

# ── Polygonscan Verification ───────────────────────────────────────────────────
# Required only if you want to verify contracts on amoy.polygonscan.com.
# Get a free key at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ── Constructor Arguments ──────────────────────────────────────────────────────
# Override the addresses used in deploy.js / deployNFT.js.
# If unset, both default to the deployer address (fine for local testing,
# but client and oracle MUST be distinct on a real deployment).
CLIENT_ADDRESS=
ORACLE_ADDRESS=

# ── Post-deployment References ─────────────────────────────────────────────────
# Fill these in after deploying so other scripts can reference the addresses.
ESCROW_ADDRESS=
NFT_ADDRESS=
